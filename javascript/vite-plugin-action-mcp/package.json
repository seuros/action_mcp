{
  "name": "@action-mcp/vite-plugin",
  "version": "0.1.0",
  "description": "Compiles vanilla MCP Apps views into self-contained bundles for the ActionMCP Rails gem",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "action-mcp-build-views": "./dist/src/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "mcp",
    "mcp-apps",
    "actionmcp",
    "vite",
    "rails"
  ],
  "peerDependencies": {
    "vite": ">=6"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.4"
  }
}
